# Environment Configuration for Emotional Understanding System

# Debug mode (True/False)
DEBUG=False

# API Server Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Model Configuration
BATCH_SIZE=32
RANDOM_SEED=42

# Feature Engineering
MAX_TEXT_LENGTH=512
MIN_TEXT_LENGTH=5

# Model Paths
MODEL_DIR=./models
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/system.log

# Feature Caching
ENABLE_FEATURE_CACHE=True
CACHE_EXPIRY_MINUTES=60

# Timeout Settings
INFERENCE_TIMEOUT=30
API_TIMEOUT=10
